{
  "name": "chartli",
  "version": "0.0.3",
  "description": "CLI for terminal charts from numeric data",
  "type": "module",
  "bin": {
    "chartli": "./dist/index.js"
  },
  "scripts": {
    "chartli": "node dist/index.js",
    "build": "tsup",
    "dev": "tsup --watch",
    "example:ascii": "bash examples/ascii.sh",
    "example:spark": "bash examples/spark.sh",
    "example:bars": "bash examples/bars.sh",
    "example:columns": "bash examples/columns.sh",
    "example:heatmap": "bash examples/heatmap.sh",
    "example:unicode": "bash examples/unicode.sh",
    "example:braille": "bash examples/braille.sh",
    "example:svg": "bash examples/svg.sh",
    "example:kitchen-sink": "bash examples/kitchen-sink.sh",
    "example:all-kitchen-sink": "bash examples/all-kitchen-sink.sh",
    "examples": "pnpm run example:kitchen-sink",
    "example:image-set:kitchen-sink": "bash examples/image-kitchen-sink.sh",
    "ex:kitchen-sink": "bash examples/image-kitchen-sink.sh",
    "test": "vitest run",
    "lint": "biome check .",
    "format": "biome format --write ."
  },
  "dependencies": {
    "@clack/prompts": "^0.9.1",
    "commander": "^12.1.0",
    "ora": "^8.2.0",
    "picocolors": "^1.1.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.13.4",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
